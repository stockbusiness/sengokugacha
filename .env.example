# LIFF ID / LINEログインチャネルID は env var ではなく管理画面(/admin/line-settings)で設定する

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 画像・動画アップロード先(Vercel Blob)。Vercelダッシュボードで
# Storage → Create Database → Blob を作成しプロジェクトに接続すると自動で追加される。
BLOB_READ_WRITE_TOKEN=

# セッションCookie署名用シークレット(openssl rand -base64 32 等で生成)
SESSION_SECRET=

# 管理画面(/admin)のログインパスワード。単独開発前提の共有パスワード方式
# このパスワードでログインすると「本部管理者」ロールになる
ADMIN_PASSWORD=

# 城主プランの「本部担当者」ロール用の別パスワード(任意)。未設定なら本部担当者
# ログインは無効(ADMIN_PASSWORDのみの既存運用のまま)。本部管理者との違いは、
# 契約の入金確定以降の遷移・報酬ルール公開・報酬確定支払・土地関連の返金など、
# 財務影響のある一部操作ができない点のみ。
ADMIN_PASSWORD_OPERATOR=

# エラー監視(Sentry)。未設定なら初期化されない(任意)。
# NEXT_PUBLIC_SENTRY_DSNはクライアント側でも使うためNEXT_PUBLIC_必須、値はSENTRY_DSNと同じでよい。
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
